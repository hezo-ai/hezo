{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "warn",
				"noUnusedVariables": "warn"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.test.ts", "**/*.spec.ts", "scripts/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					},
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		}
	],
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "always"
		}
	},
	"files": {
		"includes": [
			"**/*.ts",
			"**/*.tsx",
			"**/*.js",
			"**/*.json",
			"!**/dist",
			"!.claude",
			"!.hezo",
			"!.turbo",
			"!**/migrations-bundle.json",
			"!**/agents-bundle.json",
			"!**/routeTree.gen.ts"
		]
	}
}
