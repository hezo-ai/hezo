FROM node:24-slim

# Install common development tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl jq openssh-client ca-certificates python3 \
    && rm -rf /var/lib/apt/lists/*

# Install AI coding CLIs
RUN npm install -g @anthropic-ai/claude-code \
    && npm install -g @openai/codex-cli \
    && npm install -g @anthropic-ai/gemini-cli \
    && npm install -g @anthropic-ai/kimi-cli \
    || true

# NOTE: Package names above are placeholders — verify actual npm package names
# before building. The key requirement is that all four CLIs are available:
#   claude  (Claude Code)
#   codex   (OpenAI Codex)
#   gemini  (Google Gemini CLI)
#   kimi    (Moonshot Kimi CLI)

WORKDIR /workspace
